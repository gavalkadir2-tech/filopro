PORT=3001

# En az 32 karakterlik rastgele bir metin girin. Örnek üretmek için:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Opsiyonel: Bu sunucu, tek/özel bir şirket için mi kuruldu? (Çoğu kurulum için
# durum budur.) true yaparsanız yeni şirket kaydı tamamen kapanır — hiç kimse
# (Google ile bile) kendi kendine yeni bir şirket açamaz; sadece Ayarlar >
# Kullanıcı & Yetki'den eklediğiniz ekip üyeleri giriş yapabilir. Varsayılan:
# false (birden fazla şirketin aynı sunucuda kendi kendine kayıt olabildiği,
# SaaS tarzı çok kiracılı kurulumlar için).
TEK_SIRKET_MODU=true

# Opsiyonel: FiloPro'nun AI Asistan modülü (sohbet, arıza tahmini, maliyet
# projeksiyonu) için gereklidir. ÜCRETSİZ: console.groq.com üzerinden kredi
# kartı gerekmeden alınır.
# Boş bırakılırsa sadece AI özellikleri devre dışı kalır, senkron etkilenmez.
GROQ_API_KEY=

# Opsiyonel: şirket (tenant) başına günlük AI isteği sınırı (kötüye kullanım
# kontrolü; Groq'un ücretsiz kotası da ayrıca sınırlıdır).
AI_DAILY_LIMIT=200

# Opsiyonel: Günlük otomatik yedek e-postası için gereklidir (her gece 00:00,
# Europe/Istanbul saatiyle). Boş bırakılırsa sadece bu özellik devre dışı
# kalır, senkron ve diğer her şey etkilenmez.
#
# Gmail kullanacaksanız (önerilen, ücretsiz):
#   1. Google Hesabınızda 2 Adımlı Doğrulamayı açın.
#   2. https://myaccount.google.com/apppasswords adresinden "Uygulama Şifresi"
#      oluşturun (16 haneli bir kod verir, normal Gmail şifreniz DEĞİLDİR).
#   3. SMTP_USER'a Gmail adresinizi, SMTP_PASS'e bu 16 haneli kodu yazın.
#      SMTP_HOST/SMTP_PORT'u boş bırakın, otomatik Gmail'e bağlanır.
SMTP_USER=
SMTP_PASS=

# Opsiyonel: Gmail dışında bir SMTP sağlayıcı kullanacaksanız doldurun.
# Doluysa Gmail varsayılanı yerine bu ayarlar kullanılır.
SMTP_HOST=
SMTP_PORT=

# Opsiyonel: e-postalarda "kimden" olarak görünecek adres/isim.
# Boş bırakılırsa SMTP_USER kullanılır.
SMTP_FROM=

# Opsiyonel: "Google ile Giriş Yap" için gereklidir. Boş bırakılırsa sadece bu özellik
# devre dışı kalır, kullanıcı adı/şifre ile giriş normal şekilde çalışmaya devam eder.
#
# Kurulum:
#   1. https://console.cloud.google.com/apis/credentials adresine gidin (ücretsiz).
#   2. "Create Credentials" → "OAuth client ID" → Uygulama türü: "Web application".
#   3. "Authorized JavaScript origins" alanına FiloPro'yu açtığınız adresi ekleyin
#      (ör. https://sizin-filopro-adresiniz.com — yerelde test için http://localhost de eklenebilir).
#   4. Oluşan "İstemci Kimliği"ni (Client ID) aşağıya yapıştırın. "İstemci Gizli Anahtarı"
#      (Client Secret) BURADA GEREKMEZ, kullanmayın/paylaşmayın.
GOOGLE_CLIENT_ID=

# Render (veya benzeri) ücretsiz planlarda servis inaktifken uykuya geçtiği
# için sunucunun kendi iç saatiyle "gece 00:00'da" tetiklenmesi garanti değildir.
# Bunun yerine dış bir zamanlayıcı (ör. ücretsiz cron-job.org), her gece bu
# rastgele "sır" (secret) ile korunan uç noktayı çağırarak yedeklemeyi güvenilir
# şekilde tetikler: GET /api/backup/run-daily?secret=BU_DEGER
# Rastgele bir değer üretmek için: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# Boş bırakılırsa bu dış tetikleme uç noktası kapalı kalır (iç zamanlayıcı,
# yani sunucu tamamen sürekli açıksa çalışan yöntem, yine de aktif olur).
BACKUP_CRON_SECRET=

# Opsiyonel: Tarayıcı push bildirimleri için gereklidir (sigorta/muayene/fatura/stok
# uyarılarının günlük özetini, sekme kapalıyken bile işletim sistemi bildirim
# merkezinde gösterir). Boş bırakılırsa sadece bu özellik devre dışı kalır.
#
# Anahtar çifti üretmek için (bir kere, sunucuyu kurarken):
#   npx web-push generate-vapid-keys
# Çıktıdaki "Public Key" ve "Private Key" değerlerini aşağıya yapıştırın.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Opsiyonel: push servislerinin (Google/Mozilla vb.) sorun durumunda size ulaşabileceği
# bir iletişim adresi. Boş bırakılırsa jenerik bir değer kullanılır.
VAPID_SUBJECT=mailto:destek@sirketiniz.com
