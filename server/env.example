PORT=3001

# En az 32 karakterlik rastgele bir metin girin. Örnek üretmek için:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Opsiyonel: FiloPro'nun AI Asistan modülü (sohbet, arıza tahmini, maliyet
# projeksiyonu) için gereklidir. ÜCRETSİZ: console.groq.com üzerinden kredi
# kartı gerekmeden alınır.
# Boş bırakılırsa sadece AI özellikleri devre dışı kalır, senkron etkilenmez.
GROQ_API_KEY=

# Opsiyonel: şirket (tenant) başına günlük AI isteği sınırı (kötüye kullanım
# kontrolü; Groq'un ücretsiz kotası da ayrıca sınırlıdır).
AI_DAILY_LIMIT=200

# Opsiyonel: Günlük otomatik yedek e-postası için gereklidir (her gece 00:00,
# Europe/Istanbul saatiyle). Boş bırakılırsa sadece bu özellik devre dışı
# kalır, senkron ve diğer her şey etkilenmez.
#
# Gmail kullanacaksanız (önerilen, ücretsiz):
#   1. Google Hesabınızda 2 Adımlı Doğrulamayı açın.
#   2. https://myaccount.google.com/apppasswords adresinden "Uygulama Şifresi"
#      oluşturun (16 haneli bir kod verir, normal Gmail şifreniz DEĞİLDİR).
#   3. SMTP_USER'a Gmail adresinizi, SMTP_PASS'e bu 16 haneli kodu yazın.
#      SMTP_HOST/SMTP_PORT'u boş bırakın, otomatik Gmail'e bağlanır.
SMTP_USER=
SMTP_PASS=

# Opsiyonel: Gmail dışında bir SMTP sağlayıcı kullanacaksanız doldurun.
# Doluysa Gmail varsayılanı yerine bu ayarlar kullanılır.
SMTP_HOST=
SMTP_PORT=

# Opsiyonel: e-postalarda "kimden" olarak görünecek adres/isim.
# Boş bırakılırsa SMTP_USER kullanılır.
SMTP_FROM=

# Render (veya benzeri) ücretsiz planlarda servis inaktifken uykuya geçtiği
# için sunucunun kendi iç saatiyle "gece 00:00'da" tetiklenmesi garanti değildir.
# Bunun yerine dış bir zamanlayıcı (ör. ücretsiz cron-job.org), her gece bu
# rastgele "sır" (secret) ile korunan uç noktayı çağırarak yedeklemeyi güvenilir
# şekilde tetikler: GET /api/backup/run-daily?secret=BU_DEGER
# Rastgele bir değer üretmek için: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# Boş bırakılırsa bu dış tetikleme uç noktası kapalı kalır (iç zamanlayıcı,
# yani sunucu tamamen sürekli açıksa çalışan yöntem, yine de aktif olur).
BACKUP_CRON_SECRET=
